# ======================================
# Go Genkit Network Security Analyzer
# Environment Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Network ──────────────────────────
# Network interface to capture packets from
# macOS: en0 (Wi-Fi), en1 (Ethernet), lo0 (loopback)
# Linux: eth0, ens33, wlan0
# Run `ifconfig` or `ip a` to list interfaces
NETWORK_INTERFACE=en0

# ─── Ollama (Local AI Model) ──────────
# URL of your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use for analysis
# Make sure the model is pulled: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# ─── Telegram Bot (Optional) ──────────
# Required only for DANGEROUS IP alerts
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram chat ID (or group ID)
# Use @userinfobot to find your chat ID
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# ─── AbuseIPDB (Optional) ─────────────
# API key for AbuseIPDB threat intelligence
# Register at: https://www.abuseipdb.com/
# Leave empty to disable (geo-only analysis)
ABUSEIPDB_API_KEY=

# ─── Data Files ───────────────────────
# Path to quarantine IP list (SUSPICIOUS IPs)
QUARANTINE_FILE=data/quarantine_ips.json

# Path to blocked IP list (DANGEROUS IPs)
BLOCK_FILE=data/blocked_ips.json
